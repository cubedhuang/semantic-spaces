---
import { getCollection } from "astro:content";

import Layout from "../layouts/Layout.astro";

const words = await getCollection("words");

const threshold = 300;

const empty = words.filter((word) => !word.body?.length);
const short = words.filter((word) => word.body && word.body.length < threshold);
const done = words.filter((word) => word.body && word.body.length >= threshold);
---

<Layout
    title="Status | ilo Tani's Semantic Space Dictionary"
    description="Progress"
>
    <h1>Status <a href="/">↩</a></h1>

    <p>
        <b>{done.length} / {words.length}</b> entries done:
        {
            done.map((word, i) => (
                <>
                    <!-- prettier-ignore -->
                    <a href={`/${word.id}`}>{word.id}</a>{i !== done.length - 1 && ", "}
                </>
            ))
        }
    </p>
    <p>
        <b>{short.length} / {words.length}</b> entries with fewer than {threshold} characters:
        {
            short.map((word, i) => (
                <>
                    <!-- prettier-ignore -->
                    <a href={`/${word.id}`}>{word.id}</a>{i !== short.length - 1 && ", "}
                </>
            ))
        }
    </p>
    <p>
        <b>{empty.length} / {words.length}</b> entries empty: {
            empty.map((word) => word.id).join(", ")
        }
    </p>
</Layout>
