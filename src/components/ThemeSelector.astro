---
Astro.url.pathname;
---

<nav>
    <button data-theme="system">system</button>
    <button data-theme="light">light</button>
    <button data-theme="dark">dark</button>
    <a href="https://github.com/cubedhuang/semantic-spaces" rel="external">
        GitHub
    </a>
</nav>

<style>
    nav {
        margin-block-end: 2rem;
        display: flex;
        align-items: baseline;
        gap: 1rem;
    }
    nav a {
        margin-inline-start: auto;
    }
    nav button,
    nav a {
        text-decoration: none;
        font: inherit;
        color: var(--link);
        background: none;
        cursor: pointer;
        border: none;
        font-weight: 500;
    }
    nav button:hover,
    nav a:hover {
        text-decoration: underline;
    }
    nav button {
        margin: 0;
        padding: 0;
    }
    nav button:disabled {
        text-decoration: none;
        cursor: unset;
        color: var(--text);
    }
</style>
