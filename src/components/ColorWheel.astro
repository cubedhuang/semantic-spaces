---
const size = 300;

const lines = [30, 140, 190];
const colors = ["loje", "jelo", "laso"];

const cx = size / 2;
const cy = size / 2;
const innerR = size / 5;
const outerR = (size / 2 / Math.sqrt(2)) * 0.9;
const labelR = size / 4;

function point(angle: number, r: number) {
  const rad = (angle * Math.PI) / 180;
  return {
    x: cx + r * Math.sin(rad),
    y: cy - r * Math.cos(rad),
  };
}

const wheelLines = lines.map((angle) => ({
  inner: point(angle, innerR),
  outer: point(angle, outerR),
}));

const wheelLabels = colors.map((name, i) => {
  const a1 = lines[i];
  const a2raw = lines[(i + 1) % lines.length];
  const a2 = a2raw > a1 ? a2raw : a2raw + 360;
  const mid = ((a1 + a2) / 2) % 360;
  return { name, ...point(mid, labelR) };
});
---

<div class="figures">
  <figure class="wheel">
    <div class="wheel-ring"></div>
    <svg viewBox={`0 0 ${size} ${size}`} class="wheel-labels">
      {
        wheelLines.map(({ inner, outer }) => (
          <line
            x1={inner.x}
            y1={inner.y}
            x2={outer.x}
            y2={outer.y}
            stroke="var(--text)"
            stroke-width="2"
          />
        ))
      }
      {
        wheelLabels.map(({ name, x, y }) => (
          <text
            x={x}
            y={y}
            text-anchor="middle"
            dominant-baseline="central"
            font-size="inherit"
            font-weight="500"
            font-style="italic"
            fill="var(--text)"
          >
            {name}
          </text>
        ))
      }
    </svg>
  </figure>

  <figure class="bar">
    <div class="bar-labels">
      <span>walo</span>
      <span>pimeja</span>
    </div>
    <div class="bar-line"></div>
  </figure>
</div>

<style define:vars={{ "figure-size": size + "px" }}>
  .figures {
    margin: 2em;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  figure {
    position: relative;
    margin: 0;
  }
  .wheel-ring {
    width: var(--figure-size);
    aspect-ratio: 1;
    border-radius: 50%;
    background: conic-gradient(
      in oklch from 60deg,
      oklch(0.8 0.25 0),
      oklch(0.8 0.25 120),
      oklch(0.8 0.25 240),
      oklch(0.8 0.25 360)
    );
    mask: radial-gradient(circle, transparent 50%, black 50%);
  }
  .wheel-labels {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .bar {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
    width: var(--figure-size);
  }
  .bar-labels {
    width: 100%;
    display: flex;
    justify-content: space-between;
    font-style: italic;
    font-weight: 500;
    text-align: right;
  }
  .bar-line {
    width: 100%;
    height: 2em;
    background: linear-gradient(to right, white, black);
    border-radius: var(--figure-size);
  }
  @media (min-width: 784px) {
    .figures {
      flex-direction: row;
      justify-content: center;
      gap: 1em;
    }
    .bar {
      flex-direction: row;
      height: var(--figure-size);
      width: auto;
      gap: 0.5em;
    }
    .bar-labels {
      width: auto;
      flex-direction: column;
    }
    .bar-line {
      height: 100%;
      width: 2em;
      background: linear-gradient(to bottom, white, black);
    }
    body {
      font-size: 1.25rem;
    }
  }
</style>
