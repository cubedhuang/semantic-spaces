---
const wheelSize = 300;

const lines = [40, 140, 200];
const colors = ["loje", "jelo", "laso"];

const cx = wheelSize / 2;
const cy = wheelSize / 2;
const innerR = wheelSize / 5;
const outerR = wheelSize / 2;
const labelR = outerR * 0.5; // how far into the cutout the labels sit

function toRad(deg: number) {
  return (deg * Math.PI) / 180;
}

function point(angleDeg: number, r: number) {
  const rad = toRad(angleDeg);
  return {
    x: cx + r * Math.sin(rad),
    y: cy - r * Math.cos(rad),
  };
}

const wheelLines = lines.map((angle) => ({
  inner: point(angle, innerR),
  outer: point(angle, outerR),
}));

const wheelLabels = colors.map((name, i) => {
  const a1 = lines[i];
  const a2raw = lines[(i + 1) % lines.length];
  const a2 = a2raw > a1 ? a2raw : a2raw + 360; // handle wrap past 360
  const mid = ((a1 + a2) / 2) % 360;
  return { name, ...point(mid, labelR) };
});
---

<figure>
  <div class="wheel"></div>
  <svg viewBox={`0 0 ${wheelSize} ${wheelSize}`} class="labels">
    {
      wheelLines.map(({ inner, outer }) => (
        <line
          x1={inner.x}
          y1={inner.y}
          x2={outer.x}
          y2={outer.y}
          stroke="var(--text)"
          stroke-width="3"
        />
      ))
    }
    {
      wheelLabels.map(({ name, x, y }) => (
        <text
          x={x}
          y={y}
          text-anchor="middle"
          dominant-baseline="central"
          font-size="inherit"
          font-weight="500"
          font-style="italic"
          fill="var(--text)"
        >
          {name}
        </text>
      ))
    }
  </svg>
</figure>

<style define:vars={{ wheelSize }}>
  figure {
    position: relative;
    margin: 1em;
    display: flex;
    justify-content: center;
  }
  .wheel {
    width: calc(var(--wheelSize) * 1px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: conic-gradient(
      in oklch from 60deg,
      oklch(0.8 0.25 0),
      oklch(0.8 0.25 120),
      oklch(0.8 0.25 240),
      oklch(0.8 0.25 360)
    );
    mask: radial-gradient(circle, transparent 50%, black 50%);
  }
  .labels {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
